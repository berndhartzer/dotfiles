[user]
	email = berndhartzer@gmail.com
	name = Bernd Hartzer

[alias]
	# List files on the current branch which have been changed from the target branch
	brdiff = !sh -c 'git diff --name-only "$1"' -

[diff]
	tool = vimdiff
[core]
	excludesfile = /Users/berndhartzer/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = /Users/berndhartzer/.stCommitMsg
